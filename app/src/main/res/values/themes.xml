<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.GameShelf" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <style name="Theme.GameShelf.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#FF1A1A2E</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash</item>
        <item name="postSplashScreenTheme">@style/Theme.GameShelf</item>
    </style>
</resources>
